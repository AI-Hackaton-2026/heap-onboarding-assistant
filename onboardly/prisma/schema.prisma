// Prisma schema for Onboardly.
//
// Data-layer split (see context/current-feature.md):
//   - Prisma owns schema, migrations, and typed CRUD. It connects as the
//     `postgres` role and BYPASSES Supabase RLS, so tenant isolation
//     (an org only sees its own projects) is enforced in app logic — always
//     scope queries by the authenticated user's organization.
//   - Supabase keeps Auth, Storage, and pgvector. Vector similarity search
//     (`<=>`) is done via raw SQL / RPC, not the Prisma query builder.
//
// Connection URLs live in prisma.config.ts:
//   - DATABASE_URL: transaction-mode pooler (port 6543, ?pgbouncer=true) — app runtime
//   - DIRECT_URL:   session-mode pooler (port 5432) — migrations / introspection

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  // vector = pgvector (our embeddings). The rest ship with Supabase by default;
  // declaring them keeps `prisma migrate` from reporting drift on a fresh DB.
  extensions = [vector, pgcrypto, uuidOssp(map: "uuid-ossp"), pgStatStatements(map: "pg_stat_statements")]
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────────────────────

/// Tenant / company. Top of the ownership chain; everything scopes to an org.
model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  /// Supabase auth user id (auth.users.id) of the org owner/creator.
  ownerId   String   @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@index([ownerId])
  @@map("organizations")
}

/// A connected codebase/workspace context that knowledge + courses are built for.
model Project {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String
  description    String?
  githubRepo     String?       @map("github_repo")
  slackWorkspace String?       @map("slack_workspace")
  status         ProjectStatus @default(DRAFT)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    Document[]
  courses      Course[]
  chats        Chat[]
  integrations Integration[]
  members      ProjectMember[]

  @@index([organizationId])
  @@map("projects")
}

enum ProjectStatus {
  DRAFT
  SYNCING
  READY
  ERROR

  @@map("project_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// Knowledge ingestion
// ─────────────────────────────────────────────────────────────────────────────

/// Uploaded or synced source document (original + parsed text).
model Document {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  source      DocSource
  /// Human-readable citation label, e.g. "GitHub: backend/README.md".
  sourceLabel String       @map("source_label")
  /// Path / URL within the source (file path, doc name, Slack channel).
  sourcePath  String?      @map("source_path")
  title       String?
  mimeType    String?      @map("mime_type")
  /// Path in Supabase Storage for the original file (uploads only).
  storagePath String?      @map("storage_path")
  /// Extracted plain text used for chunking + embedding.
  content     String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  embeddings Embedding[]

  @@index([projectId])
  @@map("documents")
}

enum DocSource {
  GITHUB
  SLACK
  UPLOAD
  REPO_SUMMARY

  @@map("doc_source")
}

/// pgvector chunk: a slice of a document with its embedding + citation.
/// Gemini text-embedding-004 produces 768-dim vectors.
model Embedding {
  id          String   @id @default(uuid()) @db.Uuid
  documentId  String   @map("document_id") @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  chunkIndex  Int      @map("chunk_index")
  content     String
  /// Citation carried through to chat answers.
  sourceLabel String   @map("source_label")
  /// pgvector column — similarity search done via raw SQL (`<=>`), not Prisma.
  embedding   Unsupported("vector(768)")?
  createdAt   DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([documentId])
  @@map("embeddings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Course
// ─────────────────────────────────────────────────────────────────────────────

/// AI-generated onboarding course for a role within a project.
model Course {
  id                String   @id @default(uuid()) @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  roleName          String   @map("role_name")
  title             String
  description       String?
  estimatedMinutes  Int?     @map("estimated_minutes")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  modules Module[]

  @@index([projectId])
  @@map("courses")
}

model Module {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  title       String
  description String?
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id         String   @id @default(uuid()) @db.Uuid
  moduleId   String   @map("module_id") @db.Uuid
  title      String
  content    String?
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")

  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]
  quizzes        Quiz[]
  progress       LessonProgress[]

  @@index([moduleId])
  @@map("lessons")
}

model ChecklistItem {
  id         String  @id @default(uuid()) @db.Uuid
  lessonId   String  @map("lesson_id") @db.Uuid
  text       String
  orderIndex Int     @map("order_index")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("checklist_items")
}

/// A quiz question for a lesson. Options stored as JSON; answer is an option index.
model Quiz {
  id            String @id @default(uuid()) @db.Uuid
  lessonId      String @map("lesson_id") @db.Uuid
  question      String
  options       Json
  correctIndex  Int    @map("correct_index")
  explanation   String?
  orderIndex    Int    @map("order_index")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("quizzes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Chat
// ─────────────────────────────────────────────────────────────────────────────

/// A RAG chat session scoped to a project.
model Chat {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  /// Supabase auth user id of the participant.
  userId    String   @map("user_id") @db.Uuid
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([projectId])
  @@index([userId])
  @@map("chats")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  role      ChatRole
  content   String
  /// Source citations [{ label, path }] returned with assistant answers.
  citations Json?
  createdAt DateTime @default(now()) @map("created_at")

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("chat_messages")
}

enum ChatRole {
  USER
  ASSISTANT

  @@map("chat_role")
}

// ─────────────────────────────────────────────────────────────────────────────
// Integrations
// ─────────────────────────────────────────────────────────────────────────────

/// GitHub App / Slack App connection state for a project.
model Integration {
  id        String          @id @default(uuid()) @db.Uuid
  projectId String          @map("project_id") @db.Uuid
  type      IntegrationType
  status    IntegrationStatus @default(DISCONNECTED)
  /// Provider-specific connection details (installation id, workspace id, tokens ref).
  config    Json?
  lastSyncedAt DateTime?     @map("last_synced_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([projectId])
  @@map("integrations")
}

enum IntegrationType {
  GITHUB
  SLACK

  @@map("integration_type")
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR

  @@map("integration_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// Membership & roles
// ─────────────────────────────────────────────────────────────────────────────

/// The Onboardly directory: maps a Supabase auth user to their GitHub identity
/// so collaborator discovery can intersect "repo collaborators" with real users.
/// Populated on GitHub login from Supabase user_metadata. No FK to auth.users
/// (Prisma doesn't manage that schema) — matched in app logic by userId/login.
model UserProfile {
  id          String   @id @default(uuid()) @db.Uuid
  /// Supabase auth.users.id — one profile per user.
  userId      String   @unique @map("user_id") @db.Uuid
  email       String?
  /// GitHub username (login), captured from OAuth user_metadata. The primary
  /// identity key for collaborator matching. Stored lowercased for case-
  /// insensitive matching (GitHub logins are case-insensitive).
  githubLogin String?  @unique @map("github_login")
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([githubLogin])
  @@map("user_profiles")
}

/// A person attached to a project, with a project-level role + status.
/// Discovery adds them as ACTIVE GitHub members; Remove is a soft-delete
/// (status = REMOVED) so the row + its LessonProgress survive and re-adding
/// reactivates it. @@unique([projectId, userId]) makes add idempotent.
model ProjectMember {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  /// Supabase auth.users.id. Set immediately for this slice (members must exist).
  userId      String       @map("user_id") @db.Uuid
  /// Snapshotted identity for display + dedupe. githubLogin lowercased.
  email       String?
  githubLogin String?      @map("github_login")
  displayName String?      @map("display_name")
  avatarUrl   String?      @map("avatar_url")
  role        ProjectRole  @default(MEMBER)
  source      MemberSource @default(GITHUB)
  status      MemberStatus @default(ACTIVE)
  /// Assigned onboarding course (Phase 8+). Soft pointer — no FK relation until
  /// the course generator ships, to avoid coupling this slice to it.
  courseId    String?      @map("course_id") @db.Uuid
  joinedAt    DateTime?    @map("joined_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

enum ProjectRole {
  ADMIN
  MEMBER

  @@map("project_role")
}

enum MemberSource {
  MANUAL
  GITHUB
  SLACK

  @@map("member_source")
}

enum MemberStatus {
  INVITED
  ACTIVE
  REMOVED

  @@map("member_status")
}

/// Per-lesson progress for a member — the source of the derived onboarding %.
/// No percent is ever stored; % = completed / total course lessons, computed on
/// read. Writes land with the Course UI (Phase 9 / T-MEM-6); this slice only
/// ships the table + read/derivation so the roster has something to render.
model LessonProgress {
  id          String         @id @default(uuid()) @db.Uuid
  memberId    String         @map("member_id") @db.Uuid
  lessonId    String         @map("lesson_id") @db.Uuid
  status      ProgressStatus @default(NOT_STARTED)
  completedAt DateTime?      @map("completed_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  member ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  lesson Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([memberId, lessonId])
  @@index([memberId])
  @@map("lesson_progress")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED

  @@map("progress_status")
}
